# GitHub MCP Server Configuration
# Copy this file to .env and fill in your actual values

# ============================================================
# GitHub Authentication
# ============================================================

# Your GitHub Personal Access Token
# Get one at: https://github.com/settings/tokens
# Required scopes: repo, project, read:org
GITHUB_TOKEN=ghp_your_token_here

# ============================================================
# Default Repository Settings
# ============================================================

# GitHub username or organization name
# Used as default owner for all operations
GITHUB_OWNER=your-username

# Default repository name
# Can be overridden in individual tool calls
GITHUB_REPO=your-repo

# ============================================================
# GitHub Projects v2
# ============================================================

# Project number from the URL
# Example: If URL is github.com/users/you/projects/123, use 123
# Optional: Only needed if using project management tools
PROJECT_ID=0

# ============================================================
# Notes
# ============================================================
# - Never commit the .env file to version control
# - Add .env to your .gitignore
# - If you accidentally expose your token, revoke it immediately at:
#   https://github.com/settings/tokens
